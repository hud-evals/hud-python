    "setup_tool": [
      { "name": "launch_app", "arguments": { "app_name": "2048" } }
    ],
    "evaluate_tool": {
      "name": "evaluate",
      "arguments": { "name": "game_2048_max_number", "arguments": { "target": 128 } }
    },
    "metadata": {}
  }
]
