[
  {
    "id": "browser-2048-128",
    "prompt": "Play the 2048 game in the browser and reach at least the 128 tile..",
    "mcp_config": {
      "local": {
        "command": "docker",
        "args": ["run", "--rm", "-i", "hudevals/hud-browser:0.1.3"]
      }
