{
  "$schema": "https://mintlify.com/schema.json",
  "name": "HUD",
  "theme": "aspen",
  "logo": {
    "light": "/logo/hud_logo.svg",
    "dark": "/logo/hud_logo_dark.svg",
    "href": "https://hud.ai"
  },
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#ca8a04",
    "light": "#ffd180",
    "dark": "#1c1408"
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "farnham-headline",
      "weight": 500
    }
  },
  "appearance": {
    "default": "system"
  },
  "background": {
    "color": {
      "light": "#fafafa",
      "dark": "#17151b"
    }
  },
  "styling": {
    "codeblocks": "dark"
  },
  "css": "/custom.css",
  "icons": {
    "library": "fontawesome"
  },
  "navbar": {
    "links": [
      {
        "label": "Discord",
        "href": "https://discord.gg/wkjtmHYYjm",
        "icon": "discord",
        "iconType": "brands"
      },
      {
        "label": "X",
        "href": "https://x.com/hud_evals",
        "icon": "x-twitter",
        "iconType": "brands"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/hud-evals/hud-python"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "SDK",
        "icon": "code",
        "versions": [
          {
            "version": "v6",
            "default": true,
            "groups": [
              { "group": "Start here", "pages": ["v6/index", "v6/quickstart", "migrate-v6"] },
              { "group": "The Core", "pages": ["v6/reference/environment", "v6/reference/tasks", "v6/reference/capabilities", "v6/reference/agents", "v6/reference/runtime", "v6/reference/robots", "v6/reference/graders", "v6/protocol", "v6/reference/types", "v6/reference/cli"] },
              { "group": "Run & scale", "pages": ["v6/run/deploy", "v6/run/models", "v6/run/signal", "v6/run/training"] },
              { "group": "Advanced", "pages": ["v6/advanced/integrations", "v6/advanced/subagents", "v6/advanced/chat", "v6/advanced/patterns", "v6/advanced/harbor-convert"] },
              { "group": "Cookbooks", "pages": ["v6/cookbooks/coding-agent", "v6/cookbooks/ops-diagnostics", "v6/cookbooks/a2a-chat", "v6/cookbooks/robot-benchmark"] },
              { "group": "More", "pages": ["v6/faq", "contributing"] }
            ]
          },
          {
            "version": "v5",
            "tag": "Legacy",
            "groups": [
              {
                "group": "Get Started",
                "pages": ["v5/index", "v5/llm-quickstart", "migrate-v6"]
