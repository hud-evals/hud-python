                  "v5/reference/cli/overview",
                  "v5/reference/cli/init",
                  "v5/reference/cli/dev",
                  "v5/reference/cli/build",
                  "v5/reference/cli/deploy",
                  "v5/reference/cli/link",
                  "v5/reference/cli/push",
                  "v5/reference/cli/analyze",
