                  "v5/guides/integrations",
                  "v5/guides/chat",
                  "v5/tools/agents"
                ]
              },
              {
                "group": "Advanced",
                "pages": [
                  "v5/advanced/patterns",
                  "v5/advanced/harbor-convert",
                  "platform/publishing-leaderboards"
                ]
              },
              {
